# name: test/sql/copybook.test
# description: COBOL copybook front-end — groups (STRUCT), OCCURS (LIST),
#              REDEFINES (folded STRUCT), and the JSON spec front-end.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'fixed' AS fixed (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='fixed.main';

# Group item -> STRUCT.
query T
SELECT unpack_fixed('ABCDE042', '01 R. 05 ITEM. 10 SKU PIC X(5). 10 QTY PIC 9(3).').ITEM.SKU;
----
ABCDE

query I
SELECT unpack_fixed('ABCDE042', '01 R. 05 ITEM. 10 SKU PIC X(5). 10 QTY PIC 9(3).').ITEM.QTY;
----
42

# OCCURS -> LIST (1-based indexing in DuckDB).
query I
SELECT unpack_fixed('010203', '01 R. 05 L OCCURS 3 PIC 9(2).').L[2];
----
2

query I
SELECT len(unpack_fixed('010203', '01 R. 05 L OCCURS 3 PIC 9(2).').L);
----
3

# REDEFINES -> folded STRUCT union (both interpretations of the same bytes).
query T
SELECT unpack_fixed('00012345', '01 R. 05 RAW PIC X(8). 05 NUM REDEFINES RAW PIC 9(8).').RAW.RAW;
----
00012345

query I
SELECT unpack_fixed('00012345', '01 R. 05 RAW PIC X(8). 05 NUM REDEFINES RAW PIC 9(8).').RAW.NUM;
----
12345

# JSON spec front-end produces the same result as the template.
query I
SELECT unpack_fixed('JOHN      00042',
  '[{"name":"name","type":"str","width":10},{"name":"qty","type":"int","digits":5}]').qty;
----
42

# Binary COMP width by digit count: PIC S9(9) COMP -> 4 bytes; value 7.
query I
SELECT unpack_fixed('\x00\x00\x00\x07'::BLOB, '01 R. 05 N PIC S9(9) COMP.').N;
----
7

# JSON nested group -> STRUCT, without a COBOL copybook.
query T
SELECT unpack_fixed('HEADABC07', '[{"name":"hdr","type":"str","width":4},{"name":"item","fields":[{"name":"sku","type":"str","width":3},{"name":"qty","type":"int","digits":2}]}]').item.sku;
----
ABC

query I
SELECT unpack_fixed('HEADABC07', '[{"name":"hdr","type":"str","width":4},{"name":"item","fields":[{"name":"sku","type":"str","width":3},{"name":"qty","type":"int","digits":2}]}]').item.qty;
----
7

# JSON group + occurs -> LIST of STRUCT (1-based indexing in DuckDB).
query T
SELECT unpack_fixed('AB1CD2', '[{"name":"lines","occurs":2,"fields":[{"name":"a","type":"str","width":2},{"name":"b","type":"int","digits":1}]}]').lines[2].a;
----
CD

# Full round-trip through the Arrow path: pack(unpack(rec)) == rec for a spec
# mixing a nested group and an array-of-structs.
query T
SELECT pack_fixed(unpack_fixed('HEADABC07AB1CD2', '[{"name":"hdr","type":"str","width":4},{"name":"item","fields":[{"name":"sku","type":"str","width":3},{"name":"qty","type":"int","digits":2}]},{"name":"lines","occurs":2,"fields":[{"name":"a","type":"str","width":2},{"name":"b","type":"int","digits":1}]}]'), '[{"name":"hdr","type":"str","width":4},{"name":"item","fields":[{"name":"sku","type":"str","width":3},{"name":"qty","type":"int","digits":2}]},{"name":"lines","occurs":2,"fields":[{"name":"a","type":"str","width":2},{"name":"b","type":"int","digits":1}]}]') = 'HEADABC07AB1CD2'::BLOB;
----
true

# OCCURS … DEPENDING ON: a variable-length table whose length is driven by an
# earlier count field. The trailer after the table shifts with the table size.
query I
SELECT unpack_fixed('2AABBEND', '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).').N;
----
2

query I
SELECT len(unpack_fixed('2AABBEND', '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).').ITEMS);
----
2

query T
SELECT unpack_fixed('2AABBEND', '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).').ITEMS[2];
----
BB

# The trailer is positioned after the (variable) table body.
query T
SELECT unpack_fixed('2AABBEND', '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).').TRAILER;
----
END

# Round-trip three different table lengths (including an empty table, N=0).
query TTT
SELECT
  pack_fixed(unpack_fixed('3ABCDEFEND', '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).'), '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).')::VARCHAR,
  pack_fixed(unpack_fixed('1XYEND', '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).'), '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).')::VARCHAR,
  pack_fixed(unpack_fixed('0ZZZ', '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).'), '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).')::VARCHAR;
----
3ABCDEFEND	1XYEND	0ZZZ
