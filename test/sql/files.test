# name: test/sql/files.test
# description: read_fixed across framings + EBCDIC, and write_fixed round-trip.
#              Creates a table in the default catalog, so it does NOT set
#              search_path (that would target the read-only worker catalog) and
#              fully-qualifies the worker calls instead.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'fixed' AS fixed (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# Newline-delimited ASCII flat file.
query I
SELECT qty FROM fixed.main.read_fixed('data/accounts.dat', 'name:A10 qty:9(5)') ORDER BY qty;
----
7
42
100

# Transparent decompression — gzip, auto-detected from magic bytes (no option).
# accounts.dat.gz decodes byte-for-byte to accounts.dat, so the rows match.
query I
SELECT qty FROM fixed.main.read_fixed('data/accounts.dat.gz', 'name:A10 qty:9(5)') ORDER BY qty;
----
7
42
100

# gzip, forced explicitly.
query I
SELECT qty FROM fixed.main.read_fixed('data/accounts.dat.gz', 'name:A10 qty:9(5)',
    compression => 'gzip') ORDER BY qty;
----
7
42
100

# zstd, auto-detected from magic bytes.
query I
SELECT qty FROM fixed.main.read_fixed('data/accounts.dat.zst', 'name:A10 qty:9(5)') ORDER BY qty;
----
7
42
100

# zstd, forced explicitly.
query I
SELECT qty FROM fixed.main.read_fixed('data/accounts.dat.zst', 'name:A10 qty:9(5)',
    compression => 'zstd') ORDER BY qty;
----
7
42
100

# A plain file with compression => 'none' (and the default auto on a plain file)
# is passed through unchanged.
query I
SELECT qty FROM fixed.main.read_fixed('data/accounts.dat', 'name:A10 qty:9(5)',
    compression => 'none') ORDER BY qty;
----
7
42
100

# Forcing the wrong codec on a plain file is a hard error (no partial rows).
statement error
SELECT * FROM fixed.main.read_fixed('data/accounts.dat', 'name:A10 qty:9(5)',
    compression => 'gzip');
----
gzip decode

# Unknown compression value is rejected.
statement error
SELECT * FROM fixed.main.read_fixed('data/accounts.dat', 'name:A10 qty:9(5)',
    compression => 'lz4');
----
unknown compression

# Fixed-length unframed (no delimiters): two 15-byte records.
query T
SELECT name FROM fixed.main.read_fixed('data/accounts_fb.dat', 'name:A10 qty:9(5)', framing => 'fixed')
ORDER BY name;
----
JANE
JOHN

# EBCDIC text + COMP-3 packed decimal, fixed framing.
query T
SELECT AMT::VARCHAR FROM fixed.main.read_fixed(
    'data/ebcdic_comp3.dat',
    '01 R. 05 NM PIC X(5). 05 AMT PIC S9(3)V99 COMP-3.',
    encoding => 'ebcdic', framing => 'fixed') ORDER BY AMT;
----
-67.89
123.45

# RDW variable-length framing.
query T
SELECT s FROM fixed.main.read_fixed('data/rdw.dat', 's:A3', framing => 'rdw') ORDER BY s;
----
AAA
BBB
CCC

# RDW *blocked* framing (BDW blocks of RDW records, across two blocks).
query T
SELECT s FROM fixed.main.read_fixed('data/rdw_blocked.dat', 's:A3', framing => 'rdw_blocked')
ORDER BY s;
----
AAA
BBB
CCC

# OCCURS … DEPENDING ON: variable-length records, newline-framed. Three records
# with table lengths 2, 1, 0; the trailer shifts with each table's size.
query ITT
SELECT N, len(ITEMS), TRAILER
FROM fixed.main.read_fixed('data/odo.dat',
    '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).')
ORDER BY N DESC;
----
2	2	END
1	1	END
0	0	ZZZ

# A variable-length (ODO) layout cannot use 'fixed' framing — records have no
# constant length, so the reader rejects it.
statement error
SELECT * FROM fixed.main.read_fixed('data/odo.dat',
    '01 R. 05 N PIC 9(1). 05 ITEMS OCCURS 1 TO 9 TIMES DEPENDING ON N PIC X(2). 05 TRAILER PIC X(3).',
    framing => 'fixed');
----
DEPENDING ON

# Glob expands to multiple files (acct1.dat + acct2.dat).
query II
SELECT count(*), sum(qty)
FROM fixed.main.read_fixed('data/acct*.dat', 'name:A10 qty:9(5)');
----
3	6

# A LIST(VARCHAR) of paths reads several files in one call (rows concatenated).
query II
SELECT count(*), sum(qty)
FROM fixed.main.read_fixed(['data/acct1.dat', 'data/acct2.dat'], 'name:A10 qty:9(5)');
----
3	6

# List concatenates in the given order (acct1's qty=1, then acct2's 2, 3).
query I
SELECT qty FROM fixed.main.read_fixed(['data/acct1.dat', 'data/acct2.dat'], 'name:A10 qty:9(5)');
----
1
2
3

# Large file (5000 records) exercises the multi-batch producer.
query III
SELECT count(*), min(id), max(id)
FROM fixed.main.read_fixed('data/large.dat', 'id:9(7)');
----
5000	0	4999

# write_fixed round-trip: write a relation, read it back.
statement ok
CREATE TABLE t (name VARCHAR, qty BIGINT);

statement ok
INSERT INTO t VALUES ('ALICE', 5), ('BOB', 999);

query II
SELECT rows_written, bytes_written
FROM fixed.main.write_fixed((FROM t), 'data/_roundtrip.dat', 'name:A10 qty:9(5)');
----
2	32

query I
SELECT qty FROM fixed.main.read_fixed('data/_roundtrip.dat', 'name:A10 qty:9(5)') ORDER BY qty;
----
5
999

# write_fixed with EBCDIC + COMP-3, read back with the same options.
statement ok
CREATE TABLE acc (NM VARCHAR, AMT DECIMAL(5,2));

statement ok
INSERT INTO acc VALUES ('ACME', 123.45), ('FOO', -67.89);

statement ok
SELECT * FROM fixed.main.write_fixed((FROM acc), 'data/_ebcdic.dat',
    '01 R. 05 NM PIC X(5). 05 AMT PIC S9(3)V99 COMP-3.',
    encoding => 'ebcdic', framing => 'fixed');

query T
SELECT AMT::VARCHAR FROM fixed.main.read_fixed('data/_ebcdic.dat',
    '01 R. 05 NM PIC X(5). 05 AMT PIC S9(3)V99 COMP-3.',
    encoding => 'ebcdic', framing => 'fixed') ORDER BY AMT;
----
-67.89
123.45

# write_fixed with RDW framing, read back with RDW framing.
statement ok
CREATE TABLE r3 (s VARCHAR);

statement ok
INSERT INTO r3 VALUES ('AAA'), ('BBB'), ('CCC');

statement ok
SELECT * FROM fixed.main.write_fixed((FROM r3), 'data/_rdw.dat', 's:A3', framing => 'rdw');

query T
SELECT s FROM fixed.main.read_fixed('data/_rdw.dat', 's:A3', framing => 'rdw') ORDER BY s;
----
AAA
BBB
CCC

# write_fixed with RDW-blocked framing round-trips through a blocked reader.
statement ok
SELECT * FROM fixed.main.write_fixed((FROM r3), 'data/_rdwb.dat', 's:A3', framing => 'rdw_blocked');

query T
SELECT s FROM fixed.main.read_fixed('data/_rdwb.dat', 's:A3', framing => 'rdw_blocked') ORDER BY s;
----
AAA
BBB
CCC

# Write-side compression: a '.gz' destination is gzip-compressed (auto from the
# extension); read_fixed auto-detects + decompresses it on the way back.
statement ok
SELECT * FROM fixed.main.write_fixed((FROM t), 'data/_out.dat.gz', 'name:A10 qty:9(5)');

# The written file really is gzip (magic bytes 1f 8b), not raw text.
query T
SELECT substr(hex(content), 1, 4) FROM read_blob('data/_out.dat.gz');
----
1F8B

query I
SELECT qty FROM fixed.main.read_fixed('data/_out.dat.gz', 'name:A10 qty:9(5)') ORDER BY qty;
----
5
999

# Forced zstd via the option, written to a non-suggestive name, read back forced.
statement ok
SELECT * FROM fixed.main.write_fixed((FROM t), 'data/_out.zdat', 'name:A10 qty:9(5)',
    compression => 'zstd');

query I
SELECT qty FROM fixed.main.read_fixed('data/_out.zdat', 'name:A10 qty:9(5)',
    compression => 'zstd') ORDER BY qty;
----
5
999

# ---------------------------------------------------------------------------
# Projection pushdown (read_fixed advertises projection_pushdown = true, so the
# SDK narrows the producer's output_schema to just the requested columns). The
# producer maps each decoded field to its output column BY NAME, so a
# subset/reordered projection must land every value under the right column.

# Subset: a single non-first column. (qty is the 2nd field of the spec.)
query I
SELECT qty FROM fixed.main.read_fixed('data/accounts.dat', 'name:A10 qty:9(5)')
ORDER BY qty;
----
7
42
100

# Reordered subset over a 3-column spec: SELECT c, a (drop b, swap order). A
# positional transpose would put a's text under c / b's under a; by-name mapping
# keeps c→numeric and a→its own text.
query IT
SELECT c, a FROM fixed.main.read_fixed('data/proj.dat', 'a:A3 b:A3 c:9(3)')
ORDER BY c;
----
12	ABC
34	GHI
56	MNO

# Same file, single middle/last column only.
query I
SELECT c FROM fixed.main.read_fixed('data/proj.dat', 'a:A3 b:A3 c:9(3)') ORDER BY c;
----
12
34
56

# SELECT * still returns every column in layout order (identity projection).
query TTI
SELECT * FROM fixed.main.read_fixed('data/proj.dat', 'a:A3 b:A3 c:9(3)') ORDER BY a;
----
ABC	DEF	12
GHI	JKL	34
MNO	PQR	56
